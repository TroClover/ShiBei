# Provider: deepseek / ollama
PROVIDER=deepseek

# DeepSeek 配置
API_KEY=sk-your-deepseek-key-here
CHAT_MODEL=deepseek-v4-flash

# 嵌入配置 (ollama / openai)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
# 如嵌入用 OpenAI 则填: EMBEDDING_API_KEY=sk-your-openai-key

# Ollama 配置 (PROVIDER=ollama 时)
# CHAT_MODEL=qwen2.5

# RAG 参数
# CHUNK_SIZE=1500
# TOP_K=10
# MAX_REFLECTIONS=2
# QUALITY_THRESHOLD=0.75
